# Supabase (required for the web app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role — server only (Telegram bot, never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: Supabase CLI (`supabase link`, `db push`) — not used by Next.js
SUPABASE_ACCESS_TOKEN=

# Optional: Google Maps autocomplete on booking form
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Telegram booking bot
TELEGRAM_BOT_TOKEN=
# Group id (negative, e.g. -1001234567890) or private chat id
TELEGRAM_ALLOWED_CHAT_ID=
# Forum topic id (message_thread_id) — only process messages in this topic
TELEGRAM_ALLOWED_TOPIC_ID=
TELEGRAM_WEBHOOK_SECRET=

# OpenAI (sale message parsing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CRM tenant for the bot (defaults to piercinggentle@gmail.com if unset)
CRM_USER_EMAIL=piercinggentle@gmail.com
